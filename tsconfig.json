{
  "compilerOptions": {
    "declaration": true,
    "moduleResolution": "nodenext",
    "noUncheckedIndexedAccess": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "sourceMap": true,
    "target": "esnext",
    "module": "NodeNext"
  }
}
